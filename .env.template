# =============================================================
# 玺鸿珠宝 - 部署环境配置模板
# 复制为 .env 并填写实际值后再部署
# =============================================================

# ------- 域名 -------
API_DOMAIN=api.xihongzhubao.com
BACKSTAGE_DOMAIN=xihongzhubao.com

# ------- 后端 -------
DATABASE_URL=sqlite:////app/data/xihong.sqlite3
PUBLIC_BASE_URL=https://api.xihongzhubao.com

# ------- 管理员初始账号（首次启动自动创建） -------
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

# JWT 签名密钥（生产环境请替换为随机长字符串）
ADMIN_JWT_SECRET=change-this-to-a-random-secret

# ------- 微信小程序 -------
WECHAT_ORIGINAL_ID=
WECHAT_APPID=
WECHAT_APP_SECRET=

# ------- 微信支付 -------
WX_PAY_APPID=
WX_PAY_MCH_ID=
WX_PAY_API_V3_KEY=
WX_PAY_SERIAL_NO=
WX_PAY_PRIVATE_KEY_PATH=
WX_PAY_NOTIFY_URL=https://api.xihongzhubao.com/api/payments/wechat/notify
