<xr-scene
  ar-system="modes:Hand"
  bind:ready="handleReady"
  bind:ar-ready="handleARReady"
  bind:ar-error="handleARError"
>
  <xr-assets bind:progress="handleAssetsProgress" bind:loaded="handleAssetsLoaded">
    <xr-asset-load wx:if="{{modelUrl}}" type="gltf" asset-id="jewelry-model" src="{{modelUrl}}" />
  </xr-assets>
  <xr-node wx:if="{{arReady}}">
    <!-- auto-sync子节点映射实测偏移, 已手动修正: 子节点1234对应位置4123 -->
    <xr-ar-tracker id="tracker" mode="Hand" auto-sync="11 15 19 7" bind:ar-tracker-switch="handleTrackerSwitch">
      <xr-gltf
        wx:if="{{assetsLoaded}}"
        model="jewelry-model"
        position="{{modelPosition}}"
        rotation="{{modelRotation}}"
        scale="{{activeFinger === 7 ? modelScale : '0 0 0'}}"
      />
      <xr-gltf
        wx:if="{{assetsLoaded}}"
        model="jewelry-model"
        position="{{modelPosition}}"
        rotation="{{modelRotation}}"
        scale="{{activeFinger === 11 ? modelScale : '0 0 0'}}"
      />
      <xr-gltf
        wx:if="{{assetsLoaded}}"
        model="jewelry-model"
        position="{{modelPosition}}"
        rotation="{{modelRotation}}"
        scale="{{activeFinger === 15 ? modelScale : '0 0 0'}}"
      />
      <xr-gltf
        wx:if="{{assetsLoaded}}"
        model="jewelry-model"
        position="{{modelPosition}}"
        rotation="{{modelRotation}}"
        scale="{{activeFinger === 19 ? modelScale : '0 0 0'}}"
      />
    </xr-ar-tracker>
    <xr-camera
      id="camera"
      node-id="camera"
      clear-color="0.925 0.925 0.925 1"
      background="ar"
      is-ar-camera
      near="0.01"
    />
  </xr-node>
  <xr-node node-id="lights">
    <xr-light type="ambient" color="1 1 1" intensity="3" />
    <xr-light type="directional" rotation="45 180 0" color="1 1 1" intensity="6" />
  </xr-node>
</xr-scene>
