{
  "name": "xihong-jewelry-mp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "postinstall": "pnpm install:backend",
    "install:backend": "cd src/backend && uv sync",
    "predev": "node scripts/kill-dev-ports.mjs",
    "dev": "concurrently -n backend,miniprogram,backstage -c gray,yellow,white \"pnpm --dir src/backend dev\" \"pnpm --dir src/miniprogram dev:weapp\" \"pnpm --dir src/backstage dev\"",
    "dev:backend": "pnpm --dir src/backend dev",
    "dev:miniprogram": "pnpm --dir src/miniprogram dev:weapp",
    "dev:backstage": "pnpm --dir src/backstage dev",
    "build": "pnpm --dir src/miniprogram build:weapp && pnpm --dir src/backstage build",
    "build:miniprogram": "pnpm --dir src/miniprogram build:weapp",
    "build:backstage": "pnpm --dir src/backstage build",
    "test:backend": "pnpm --dir src/backend test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
